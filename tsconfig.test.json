{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": ".test-build",
    "rootDir": "src",
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/core/**/*.ts"],
  "exclude": ["node_modules", ".test-build"]
}
